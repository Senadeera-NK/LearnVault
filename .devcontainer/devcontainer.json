{
  "name": "Frontend",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  "postCreateCommand": "cd frontend && npm install && npm install next react react-dom",

  "forwardPorts": [3000],

  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "openPreview"
    }
  },

  "postStartCommand": "cd frontend && npm run dev"
}
